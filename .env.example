# Copy to .env and adjust for your deployment. None of these are required
# for local dev or the zero-config demo - defaults are chosen so the app
# runs with no environment configured at all.

# --- server/ -----------------------------------------------------------

# Port the Express/Socket.IO server listens on.
PORT=4000

# Where the SQLite event-log database is stored.
DATA_DIR=./server/data

# Which bundled region's intersection grid this controller instance serves.
# See shared/src/regions.js for the catalog (metroville, manhattan, sydney).
# One controller manages one region, same as a real municipal deployment.
REGION_ID=metroville

# Comma-separated list of dashboard origins allowed to call the API / open
# a Socket.IO connection, e.g. https://traffic.example.com. Defaults to "*"
# (any origin) when unset, which is fine for a public demo but should be
# locked down for a real deployment.
CORS_ORIGIN=

# When set, write endpoints (POST /dispatch, /recall/:id, /auto-dispatch,
# /telemetry) require this value in an `x-api-key` header. Unset = no
# auth, which is fine for local dev/demo but not for a public production
# deployment that real IoT hardware or an open dashboard can reach.
TRAFFIC_API_KEY=

# --- client/ (build-time only) ------------------------------------------

# Base URL of the backend the dashboard should talk to. Leave unset to use
# the page's own origin (the default for Docker Compose / single-process
# deployments where client and server are reverse-proxied together).
VITE_BACKEND_URL=
